<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="7dp"
    android:layout_marginLeft="5dp"
    android:layout_marginRight="5dp"
    android:background="@drawable/roundedbg"
    android:orientation="vertical"
    android:padding="9dp">

    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="🤖 LLM-Driven Updates"
        android:textColor="@color/textprimary"
        android:textSize="20dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This app is now maintained and updated exclusively by an AI large language model (LLM) — specifically, Antigravity (powered by Google DeepMind Gemini).\n\nWhat does this mean?\nInstead of a human developer writing code manually, an AI agent reads the codebase, understands the structure, and implements new features, bug fixes, and improvements autonomously. The human owner provides high-level instructions, and the LLM handles all the coding, layout changes, logic updates, and testing.\n\nWhat to expect:\n• Updates may arrive more frequently, since there is no human bottleneck\n• Changelogs will reflect AI-authored commits\n• The app's direction is still guided by the owner—just executed by AI\n• Quality is maintained through careful prompting and review\n\nThis is an experimental approach to app maintenance, and you are witnessing it firsthand."
        android:textColor="@color/textprimary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/repobtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            android:background="@drawable/roundedbgviolent"
            android:gravity="center_horizontal|center_vertical"
            android:padding="8dp"
            android:text="App Repo"
            android:textColor="@color/textprimary"
            android:textSize="16dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/closebtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/roundedbgviolent"
            android:gravity="center_horizontal|center_vertical"
            android:padding="8dp"
            android:text="I understand"
            android:textColor="@color/textprimary"
            android:textSize="16dp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>